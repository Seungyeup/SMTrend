FINNHUB_API_KEY=
FRED_API_KEY=
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
SUPERSET_HOST_PORT=8088

# Continuous market producer (Superset monitoring)
MARKET_MOCK_SYMBOL=GOOG
MARKET_MOCK_COUNT=0
MARKET_MOCK_INTERVAL_S=1
MARKET_MOCK_START_PRICE=180.0

# Kafka topic retention days
RAW_MARKET_RETENTION_DAYS=7
RAW_MACRO_RETENTION_DAYS=365
CURATED_MARKET_RETENTION_DAYS=30
STATE_MACRO_RETENTION_DAYS=365
ANALYTICS_RETENTION_DAYS=30
DLQ_MARKET_RETENTION_DAYS=14
DLQ_MACRO_RETENTION_DAYS=14

# Druid datasource retention days
DRUID_RETENTION_DAYS=30

# Superset dashboard/chart live view defaults
SUPERSET_TIMESERIES_TIME_RANGE=Last 1 hour
SUPERSET_DASHBOARD_REFRESH_SECONDS=10
